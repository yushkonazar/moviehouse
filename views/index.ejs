<%- include('partials/header') %>

<div class="relative min-h-screen flex items-center justify-center"
    style="background-image: url('/images/main_background.png'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-gray-900 to-transparent"></div>
    <div class="relative z-10 text-center px-4 max-w-3xl">
        <h1 class="text-5xl font-bold text-white mb-6 leading-tight"
            style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.05em;">
            Твій кіносвіт —<br>в одному місці
        </h1>
        <p class="text-gray-300 text-lg mb-8 leading-relaxed">
            Відкривай трендові новинки, шукай улюблені фільми та знаходь де їх переглянути.
        </p>
        <div class="flex gap-4 justify-center">
            <a href="#"
            onclick="window.scrollTo({top: 0, behavior: 'smooth'}); setTimeout(() => document.querySelector('input[name=q]').focus(), 600); return false;"
            class="inline-block bg-red-600 hover:bg-red-500 text-white px-8 py-3 rounded-full text-sm font-semibold transition-all duration-300 hover:scale-105">
                Почати пошук
            </a>
            <a href="#movies" 
            class="inline-block bg-transparent hover:bg-white/10 text-white border border-white/40 hover:border-white px-8 py-3 rounded-full text-sm font-semibold transition-all duration-300 hover:scale-105">
                Переглянути фільми
            </a>
        </div>
    </div>
</div>

<main id="movies" class="pb-10 px-4 pt-16">
    <div class="mb-12">
        <div class="flex justify-between items-center mb-4 px-4">
            <h2 class="text-2xl font-bold">Зараз у тренді</h2>
            <div class="flex gap-2">
                <button onclick="slide('trending', -1)"
                        class="w-9 h-9 rounded-full bg-gray-800 hover:bg-red-600 text-white transition-colors duration-300 flex items-center justify-center">
                        ←
                </button>
                <button onclick="slide('trending', 1)"
                        class="w-9 h-9 rounded-full bg-gray-800 hover:bg-red-600 text-white transition-colors duration-300 flex items-center justify-center">
                        →
                </button>
            </div>            
        </div>
        <div id="trending" class="flex gap-4 overflow-x-auto scrollbar-hide scroll-smooth px-4 pb-4">
            <% trending.forEach(movie => { %>
                <a href="/movie/<%= movie.id %>"
                    class="shrink-0 w-44 bg-gray-800 rounded-lg overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300 block">
                    <img 
                        src="<%= movie.poster_path ? 'https://image.tmdb.org/t/p/w500' + movie.poster_path : '/images/no-poster.svg' %>"
                        alt="<%= movie.title%>"
                        class="w-full h-64 object-cover"
                    >
                    <div class="p-3">
                        <h3 class="font-bold text-sm truncate"><%= movie.title %></h3>
                        <div class="flex justify-between items-center mt-1 text-xs text-gray-400">
                            <span><%= movie.release_date ? movie.release_date.split('-')[0] : '—' %></span>
                            <span class="text-yellow-500 font-semibold">⭐ <%= movie.vote_average.toFixed(1) %></span>
                        </div>
                    </div>                    
                </a>
            <% }) %>
        </div>
    </div>

    <div class="mb-12">
        <div class="flex justify-between items-center mb-4 px-4">
            <h2 class="text-2xl font-bold">Топ рейтингу</h2>
            <div class="flex gap-2">
                <button onclick="slide('popular', -1)" 
                    class="w-9 h-9 rounded-full bg-gray-800 hover:bg-red-600 text-white transition-colors duration-200 flex items-center justify-center">
                    ←
                </button>
                <button onclick="slide('popular', 1)" 
                    class="w-9 h-9 rounded-full bg-gray-800 hover:bg-red-600 text-white transition-colors duration-200 flex items-center justify-center">
                    →
                </button>
            </div>
        </div>
        <div id="popular" class="flex gap-4 overflow-x-auto scrollbar-hide scroll-smooth px-4 pb-4">
            <% popular.forEach(movie => { %>
                <a href="/movie/<%= movie.id %>" 
                   class="shrink-0 w-44 bg-gray-800 rounded-lg overflow-hidden shadow-lg hover:scale-105 transition-transform duration-300 block">
                    <img 
                        src="<%= movie.poster_path ? 'https://image.tmdb.org/t/p/w500' + movie.poster_path : '/images/no-poster.svg' %>"
                        alt="<%= movie.title %>"
                        class="w-full h-64 object-cover"
                    >
                    <div class="p-3">
                        <h3 class="font-bold text-sm truncate"><%= movie.title %></h3>
                        <div class="flex justify-between items-center mt-1 text-xs text-gray-400">
                            <span><%= movie.release_date ? movie.release_date.split('-')[0] : '—' %></span>
                            <span class="text-yellow-500 font-semibold">⭐ <%= movie.vote_average.toFixed(1) %></span>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</main>
<%- include('partials/footer') %>