<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MovieHouse</title>
    <link rel="icon" href="/images/icon.svg">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-gray-900 text-white min-h-screen flex flex-col">
    <nav class="fixed top-0 left-0 right-0 z-50 p-6 <%= heroHeader ? 'bg-gradient-to-b from-black/80 to-transparent' : 'bg-black/30 backdrop-blur-sm border-b border-white/10 border-burn' %>">
        <div class="container mx-auto flex justify-between items-center">
            <a href="/" 
                class="text-4xl font-bold text-red-500 drop-shadow-lg hover:text-red-700 transition-colors duration-200 tracking-wider"
                style="font-family: 'Bebas Neue', sans-serif; text-shadow: 0 0 20px rgba(239, 68, 68, 0.8), 0 0 40px rgba(239, 68, 68, 0.4);">
                MovieHouse
            </a>
            <div class="flex items-center gap-4">
                <form action="/search" method="get" class="flex items-center">
                        <input 
                            type="text"
                            name="q"
                            placeholder="Пошук фільму..."
                            autocomplete="off"
                            maxlength="80"
                            value="<%= typeof query !== 'undefined' ? query : '' %>"
                            class="bg-gray-800 text-white text-sm px-4 py-2 outline-none border border-gray-700 focus:border-red-500 transition-all duration-300 w-36 focus:w-64 rounded-l-full"
                            >
                        <button 
                            type="submit"
                            class="bg-red-600 hover:bg-red-500 text-white text-sm px-4 py-2 rounded-r-full border border-red-600 hover:border-red-500 transition-colors duration-200">
                            <img src="/images/search-icon.svg" alt="Пошук" class="w-5 h-5 invert">
                        </button>
                </form>
            </div>
        </div>
    </nav>